<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/keyboard_container" android:layout_width="match_parent" android:layout_height="match_parent">
  <View android:id="@+id/dock_indicator" android:layout_width="match_parent" android:layout_height="60dp" android:layout_gravity="bottom" android:background="#333399FF" android:visibility="gone" />
  <ImageView android:id="@+id/keyboard_collapsed_icon" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_expand" android:background="@drawable/bg_collapsed_icon" android:padding="10dp" android:elevation="0dp" android:visibility="gone" />
  <LinearLayout android:id="@+id/keyboard_content" android:layout_width="match_parent" android:layout_height="wrap_content" android:hardwareAccelerated="false" android:orientation="vertical" android:background="?attr/colorKeyboard" android:elevation="8dp">
    <FrameLayout android:id="@+id/toolbar_container" android:layout_width="match_parent" android:layout_height="wrap_content">
      <LinearLayout android:id="@+id/toolbar" android:layout_width="match_parent" android:layout_height="36dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingLeft="8dp" android:paddingRight="8dp" android:background="?attr/colorKeyboard">
        <ImageView android:id="@+id/btn_toggle_floating" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_floating" android:tint="?attr/colorLabel" android:contentDescription="@string/key_descr_toggle_floating" android:layout_marginRight="20dp" android:padding="4dp" android:scaleType="centerInside" />
        <ImageView android:id="@+id/btn_settings" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_settings" android:tint="?attr/colorLabel" android:contentDescription="@string/pref_category_behavior" android:layout_marginRight="20dp" android:padding="4dp" android:scaleType="centerInside" />
        <ImageView android:id="@+id/btn_brightness" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_brightness" android:tint="?attr/colorLabel" android:contentDescription="Adjust Brightness" android:layout_marginRight="20dp" android:padding="4dp" android:scaleType="centerInside" />
        <ImageView android:id="@+id/btn_clipboard" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_clipboard" android:tint="?attr/colorLabel" android:contentDescription="Clipboard History" android:layout_marginRight="20dp" android:padding="4dp" android:scaleType="centerInside" />
        <ImageView android:id="@+id/btn_toggle_split" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_split" android:tint="?attr/colorLabel" android:contentDescription="Toggle Split Layout" android:layout_marginRight="20dp" android:padding="4dp" android:scaleType="centerInside" />
        <ImageView android:id="@+id/btn_collapse" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_collapse" android:tint="?attr/colorLabel" android:contentDescription="Collapse Keyboard" android:layout_marginRight="20dp" android:padding="4dp" android:scaleType="centerInside" />
        <ImageView android:id="@+id/btn_reset_floating" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_reset" android:tint="?attr/colorLabel" android:contentDescription="Reset Position" android:padding="4dp" android:scaleType="centerInside" android:visibility="gone" />
      </LinearLayout>
      <juloo.keyboard2.suggestions.CandidatesView android:id="@+id/candidates_view" style="@style/candidates_view" android:visibility="gone" android:layout_height="36dp">
        <TextView android:id="@+id/candidates_emoji" style="@style/candidates_emoji"/>
        <TextView android:id="@+id/candidates_left" style="@style/candidates_item"/>
        <TextView android:id="@+id/candidates_middle" style="@style/candidates_item"/>
        <TextView android:id="@+id/candidates_right" style="@style/candidates_item"/>
      </juloo.keyboard2.suggestions.CandidatesView>
      <LinearLayout android:id="@+id/brightness_slider_container" android:layout_width="match_parent" android:layout_height="36dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingLeft="8dp" android:paddingRight="8dp" android:background="?attr/colorKeyboard" android:visibility="gone">
        <ImageView android:id="@+id/btn_close_brightness" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_collapse" android:tint="?attr/colorLabel" android:padding="4dp" android:scaleType="centerInside" />
        <SeekBar android:id="@+id/brightness_seekbar" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="100" />
        <TextView android:id="@+id/brightness_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorLabel" android:textSize="12sp" android:paddingLeft="8dp" />
      </LinearLayout>
    </FrameLayout>
    <juloo.keyboard2.Keyboard2View android:id="@+id/keyboard_view" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
    <FrameLayout android:id="@+id/bottom_controls" android:layout_width="match_parent" android:layout_height="wrap_content">
      <View android:id="@+id/drag_handle" android:layout_width="120dp" android:layout_height="32dp" android:layout_gravity="center" android:background="@drawable/bg_drag_handle" android:visibility="gone" />
      <ImageView android:id="@+id/resize_handle" android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="bottom|right" android:src="@drawable/ic_resize" android:scaleType="centerInside" android:padding="6dp" android:visibility="gone" android:layout_margin="0dp"/>
    </FrameLayout>
  </LinearLayout>
</FrameLayout>
